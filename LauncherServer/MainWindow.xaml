<Window x:Class="PangyaLauncherServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pangya — Launcher Server"
        Height="780" Width="1220"
        MinHeight="680" MinWidth="1000"
        Background="#12121E"
        WindowStartupLocation="CenterScreen"
        Icon="/icon.ico">

    <Window.Resources>
        <!-- Base button style -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton style -->
        <Style x:Key="ServerToggle" TargetType="ToggleButton">
            <Setter Property="Width"           Value="110"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#3A8DFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#28A745"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card border -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"    Value="#1E1E30"/>
            <Setter Property="CornerRadius"  Value="10"/>
            <Setter Property="Padding"       Value="16,12"/>
            <Setter Property="Margin"        Value="8"/>
        </Style>

        <!-- TabItem style -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground"     Value="#AAAACC"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Padding"        Value="12,6"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <!-- Header bar -->
            <RowDefinition Height="Auto"/>
            <!-- Server cards -->
            <RowDefinition Height="*"/>
            <!-- Log tabs -->
            <RowDefinition Height="48"/>
            <!-- Footer toolbar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════ HEADER ══════════ -->
        <Border Grid.Row="0" Background="#0D0D1A">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⛳" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Pangya" FontSize="20" FontWeight="Bold"
                               Foreground="#3A8DFF" VerticalAlignment="Center"/>
                    <TextBlock Text="  Launcher Server" FontSize="16"
                               Foreground="#CCCCDD" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Global action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnStartAll"   Content="▶  Start All"   Width="110" Height="32"
                            Background="#28A745" Padding="8,0" Margin="4,0"
                            Style="{StaticResource FlatBtn}"
                            Click="StartAll_Click"/>
                    <Button x:Name="BtnRestartAll" Content="↻  Restart All" Width="115" Height="32"
                            Background="#E6A817" Padding="8,0" Margin="4,0"
                            Style="{StaticResource FlatBtn}"
                            Click="RestartAll_Click"/>
                    <Button Content="■  Stop All"   Width="110" Height="32"
                            Background="#DC3545" Padding="8,0" Margin="4,0"
                            Style="{StaticResource FlatBtn}"
                            Click="StopAll_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ SERVER CARDS ════ -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="CardsPanel" HorizontalAlignment="Center"
                       Margin="8,10">

                <!-- AUTH -->
                <Border Style="{StaticResource Card}" Width="210">
                    <StackPanel>
                        <TextBlock Text="Auth Server" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ToggleButton x:Name="AuthToggle" Content="Start / Stop"
                                      Style="{StaticResource ServerToggle}"
                                      Click="ServerToggle_Click"/>
                        <TextBlock x:Name="AuthStatus"  Text="○ Offline"
                                   Foreground="Gray"  FontSize="11" Margin="0,8,0,2"/>
                        <TextBlock x:Name="AuthUptime"  Text="Up: —"
                                   Foreground="#6666AA" FontSize="10"/>
                        <TextBlock x:Name="AuthCrashes" Text="Crashes: 0  Restarts: 0"
                                   Foreground="#555577" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- LOGIN -->
                <Border Style="{StaticResource Card}" Width="210">
                    <StackPanel>
                        <TextBlock Text="Login Server" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ToggleButton x:Name="LoginToggle" Content="Start / Stop"
                                      Style="{StaticResource ServerToggle}"
                                      Click="ServerToggle_Click"/>
                        <TextBlock x:Name="LoginStatus"  Text="○ Offline"
                                   Foreground="Gray"  FontSize="11" Margin="0,8,0,2"/>
                        <TextBlock x:Name="LoginUptime"  Text="Up: —"
                                   Foreground="#6666AA" FontSize="10"/>
                        <TextBlock x:Name="LoginCrashes" Text="Crashes: 0  Restarts: 0"
                                   Foreground="#555577" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- GAME -->
                <Border Style="{StaticResource Card}" Width="210">
                    <StackPanel>
                        <TextBlock Text="Game Server" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ToggleButton x:Name="GameToggle" Content="Start / Stop"
                                      Style="{StaticResource ServerToggle}"
                                      Click="ServerToggle_Click"/>
                        <TextBlock x:Name="GameStatus"  Text="○ Offline"
                                   Foreground="Gray"  FontSize="11" Margin="0,8,0,2"/>
                        <TextBlock x:Name="GameUptime"  Text="Up: —"
                                   Foreground="#6666AA" FontSize="10"/>
                        <TextBlock x:Name="GameCrashes" Text="Crashes: 0  Restarts: 0"
                                   Foreground="#555577" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- RANK -->
                <Border Style="{StaticResource Card}" Width="210">
                    <StackPanel>
                        <TextBlock Text="Rank Server" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ToggleButton x:Name="RankToggle" Content="Start / Stop"
                                      Style="{StaticResource ServerToggle}"
                                      Click="ServerToggle_Click"/>
                        <TextBlock x:Name="RankStatus"  Text="○ Offline"
                                   Foreground="Gray"  FontSize="11" Margin="0,8,0,2"/>
                        <TextBlock x:Name="RankUptime"  Text="Up: —"
                                   Foreground="#6666AA" FontSize="10"/>
                        <TextBlock x:Name="RankCrashes" Text="Crashes: 0  Restarts: 0"
                                   Foreground="#555577" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- MESSENGER -->
                <Border Style="{StaticResource Card}" Width="210">
                    <StackPanel>
                        <TextBlock Text="Messenger Server" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>
                        <ToggleButton x:Name="MessengerToggle" Content="Start / Stop"
                                      Style="{StaticResource ServerToggle}"
                                      Click="ServerToggle_Click"/>
                        <TextBlock x:Name="MessengerStatus"  Text="○ Offline"
                                   Foreground="Gray"  FontSize="11" Margin="0,8,0,2"/>
                        <TextBlock x:Name="MessengerUptime"  Text="Up: —"
                                   Foreground="#6666AA" FontSize="10"/>
                        <TextBlock x:Name="MessengerCrashes" Text="Crashes: 0  Restarts: 0"
                                   Foreground="#555577" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════ LOG TABS ════════ -->
        <TabControl x:Name="ServerTabControl" Grid.Row="2"
                    Background="#1A1A28" BorderThickness="0"
                    Margin="8,0,8,0">

            <TabItem Header="Auth Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#12121E">
                    <RichTextBox x:Name="AuthLog"
                                 IsReadOnly="True" Background="#12121E"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Login Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#12121E">
                    <RichTextBox x:Name="LoginLog"
                                 IsReadOnly="True" Background="#12121E"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Game Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#12121E">
                    <RichTextBox x:Name="GameLog"
                                 IsReadOnly="True" Background="#12121E"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Rank Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#12121E">
                    <RichTextBox x:Name="RankLog"
                                 IsReadOnly="True" Background="#12121E"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Messenger Server">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#12121E">
                    <RichTextBox x:Name="MessengerLog"
                                 IsReadOnly="True" Background="#12121E"
                                 FontFamily="Consolas" FontSize="12"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════ FOOTER TOOLBAR ══ -->
        <Border Grid.Row="3" Background="#0D0D1A" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button Content="🗑  Clear Log"    Width="110" Height="30"
                        Background="#444466" Padding="6,0" Margin="4,0"
                        Style="{StaticResource FlatBtn}"
                        Click="ClearLog_Click"/>

                <Button Content="📄  Export CSV"  Width="115" Height="30"
                        Background="#2255AA" Padding="6,0" Margin="4,0"
                        Style="{StaticResource FlatBtn}"
                        Click="ExportLog_Click"/>

                <Button Content="📊  Export Stats" Width="120" Height="30"
                        Background="#225588" Padding="6,0" Margin="4,0"
                        Style="{StaticResource FlatBtn}"
                        Click="ExportStats_Click"/>

                <Button Content="🧹  Purge Old Logs" Width="130" Height="30"
                        Background="#553322" Padding="6,0" Margin="4,0"
                        Style="{StaticResource FlatBtn}"
                        Click="PurgeLogs_Click"/>

                <TextBlock Text="Pangya Launcher Server  |  v2.0"
                           Foreground="#333355" FontSize="10"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
